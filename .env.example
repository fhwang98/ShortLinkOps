# 로컬 Spring Boot 실행
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/shortlink?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=shortlink
SPRING_DATASOURCE_PASSWORD=shortlink_pw
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# EC2 운영 배포에서는 https://www.fhwang.cloud 값을 사용합니다.
SHORTLINKOPS_BASE_URL=http://localhost:8080

# 운영 Docker Compose
APP_IMAGE=your-dockerhub-username/shortlinkops:latest
MYSQL_USER=shortlink
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root
