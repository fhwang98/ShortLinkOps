# Auto-detect text files and normalize line endings to LF in repository
* text=auto

# Shell scripts and Gradle wrapper must use LF
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Source code
*.java text eol=lf
*.kt text eol=lf
*.groovy text eol=lf
*.gradle text eol=lf

# Web / template files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Archives / binaries
*.jar binary
*.war binary
*.zip binary
*.tar.gz binary
*.rar binary
